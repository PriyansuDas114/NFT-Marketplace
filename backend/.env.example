# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────────
# Local:    mongodb://127.0.0.1:27017/nexmint
# Atlas:    mongodb+srv://user:pass@cluster.mongodb.net/nexmint
MONGO_URI=mongodb://127.0.0.1:27017/nexmint

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Auth ──────────────────────────────────────────────────
# Used for nonce-based SIWE message signing
NONCE_SECRET=change_me_to_a_random_64_char_string

# ─── Contracts (for blockchain event listeners) ────────────
MARKETPLACE_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
NFT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
RPC_URL=http://127.0.0.1:8545
